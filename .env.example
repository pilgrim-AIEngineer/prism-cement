# Supabase Postgres connection strings.
#
# DATABASE_URL — POOLED connection (PgBouncer, port 6543). The app and
#   `lib/db.ts` use this at runtime. Never run migrations through it.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT_REF].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL — DIRECT connection (port 5432). Migrations only
#   (`npm run db:migrate`, `prisma migrate ...`). The pooler does not support
#   the prepared statements / DDL that migrations require.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT_REF].supabase.com:5432/postgres"

# Mock-OTP auth (lib/auth/verifyOtp). MVP accepts any phone number; the OTP
# must equal this value. Swap this for a real SMS provider in Phase 2 — the
# whole stub lives behind lib/auth/verifyOtp() for a one-line swap.
MOCK_OTP_CODE="123456"

# Secret used to sign session JWTs issued by lib/auth.
AUTH_SECRET="replace-with-a-long-random-string"

# Phone for the seed-only Admin account (prisma/seed.ts). ADMIN never
# self-registers — sign in with this number + the mock OTP to reach /admin.
SEED_ADMIN_PHONE="+910000000000"
